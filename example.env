############################################################
# MatchZy Auto Tournament – Example .env
#
# Copy this file to `.env` at the repo root and adjust values.
# The API reads `.env` via dotenv on startup.
############################################################

##############################
# ---- Core server settings --
##############################

# Environment: development or production (optional; defaults to development)
# NODE_ENV=development

# API port (behind Caddy/Docker this is usually 3000)
PORT=3000

# Session secret for Passport/express-session
# Generate a strong random value, for example:
#   openssl rand -base64 32
SESSION_SECRET=change-this-session-secret

########################
# ---- Database --------
########################

# Option A: Single DATABASE_URL (preferred in Docker)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/matchzy_tournament

# Option B: Individual DB settings (for local dev without DATABASE_URL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=matchzy_tournament

###############################
# ---- CS2 server integration -
###############################

# Token used by CS2 servers to authenticate webhooks and match load requests.
# This must match the token configured in MatchZy on your game servers.
# Example (simple random token):
#   SERVER_TOKEN=$(openssl rand -base64 24 | tr -d '=+/')
SERVER_TOKEN=your-server-token-here

#############################
# ---- Auth providers (SSO) -
#############################

## Shared auth settings

# Public base URL of MAT, used to compute post-login redirects for ALL providers.
# Required when you enable any auth provider. Local Docker default:
FRONTEND_BASE_URL=http://localhost:3069

## Steam (primary – players + admins)

# Enable/disable Steam as an auth provider
AUTH_STEAM_ENABLED=true

# Required: Steam Web API key (obtain from https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=your-steam-web-api-key

## Keycloak (OIDC) – optional

# AUTH_KEYCLOAK_ENABLED=false
# Required when AUTH_KEYCLOAK_ENABLED=true
# KEYCLOAK_ISSUER_URL=
# KEYCLOAK_CLIENT_ID=
# KEYCLOAK_CLIENT_SECRET=
# Optional override; defaults to /api/auth/keycloak/callback (relative to FRONTEND_BASE_URL)
# KEYCLOAK_CALLBACK_PATH=/api/auth/keycloak/callback

## Discord (OAuth2) – optional

# AUTH_DISCORD_ENABLED=false
# Required when AUTH_DISCORD_ENABLED=true
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# Required when AUTH_DISCORD_ENABLED=true – full redirect URI; must match your Discord app config
# DISCORD_REDIRECT_URI=

## GitHub (OAuth2) – optional

# AUTH_GITHUB_ENABLED=false
# Required when AUTH_GITHUB_ENABLED=true
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# Required when AUTH_GITHUB_ENABLED=true – full callback URL; must match your GitHub OAuth app config
# GITHUB_CALLBACK_URL=

############################
# ---- Logging & debug ----
############################

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Set to false to disable per-request HTTP logs (still logs 4xx/5xx) – optional
# LOG_HTTP_REQUESTS=true

# Enable verbose per-query DB logs – optional
# LOG_DB_VERBOSE=false

# Enable verbose RCON success logs – optional
# LOG_RCON_VERBOSE=false

################################
# ---- CORS / WebSockets ------- 
################################

# Allowed CORS origin(s) for Socket.IO and API (comma-separated) – optional
# In Docker with Caddy, this is usually handled at the proxy layer.
# CORS_ORIGIN=*

#####################################
# ---- Optional: simulation mode ----
#####################################

# Allow enabling "simulation" features in production (advanced) – optional
# MATCHZY_ENABLE_SIMULATION_IN_PROD=false

###########################
# ---- Misc / tooling ----
###########################

# GitHub token used by fetchCS2Maps to call the GitHub API – optional
# GITHUB_TOKEN=

# Playwright base URL for E2E tests – optional (defaults to http://localhost:3069 in tests)
# PLAYWRIGHT_BASE_URL=http://localhost:3069

# Steam ID to use for the test admin in Playwright/tests/scripts – optional
# TEST_STEAM_ID=76561198000000001