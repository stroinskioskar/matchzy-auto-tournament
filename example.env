############################################################
# MatchZy Auto Tournament – Example .env
#
# Copy this file to `.env` at the repo root and adjust values.
# The API reads `.env` via dotenv on startup.
#
# Docker Compose: The docker-compose.yml files use env_file to load
# all variables from .env into the container automatically.
############################################################

##############################
# ---- Core server settings --
##############################

# Environment: development or production (optional; defaults to development)
# NODE_ENV=development

# API port (behind Caddy/Docker this is usually 3000)
PORT=3000

# Session secret for Passport/express-session
# REQUIRED: Generate a strong random value, for example:
#   openssl rand -base64 32
# Without this, sessions won't persist across container restarts
SESSION_SECRET=change-this-session-secret

########################
# ---- Database --------
########################

# Option A: Single DATABASE_URL (preferred in Docker)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/matchzy_tournament

# Option B: Individual DB settings (for local dev without DATABASE_URL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=matchzy_tournament

###############################
# ---- CS2 server integration -
###############################

# Token used by CS2 servers to authenticate webhooks and match load requests.
# This must match the token configured in MatchZy on your game servers.
# Example (simple random token):
#   SERVER_TOKEN=$(openssl rand -base64 24 | tr -d '=+/')
SERVER_TOKEN=your-server-token-here

# Webhook base URL for MatchZy to send events to the API.
# This should point to your API server (NOT the frontend dev server).
# Examples:
#   - Local dev: http://localhost:3000
#   - Production: http://your-server-ip:3069 or https://your-domain.com
# If not set, auto-detects as http://localhost:{PORT}
# API_BASE_URL=http://localhost:3000

#############################
# ---- Auth providers (SSO) -
#############################

## Shared auth settings

# Public base URL of MAT frontend, used for OAuth redirects (Steam, Discord, etc.).
# Required when you enable any auth provider.
# IMPORTANT: 
#   - Use http:// for local development (e.g., http://localhost:5173 for Vite dev, or :3069 for Docker)
#   - Use https:// for production (e.g., https://your-domain.com)
# The secure cookie flag is automatically set based on this URL (https:// = secure cookies)
FRONTEND_BASE_URL=http://localhost:3069

## Steam (primary – players + admins)

# Enable/disable Steam as an auth provider
AUTH_STEAM_ENABLED=true

# Required: Steam Web API key (obtain from https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=your-steam-web-api-key

## Keycloak (OIDC) – optional

# Example (uncomment and fill in to enable Keycloak SSO for admins):
# AUTH_KEYCLOAK_ENABLED=true
# KEYCLOAK_ISSUER_URL=https://sso.example.com/realms/matchzy
# KEYCLOAK_CLIENT_ID=matchzy-dashboard
# KEYCLOAK_CLIENT_SECRET=your-keycloak-secret
#   # In your Keycloak client, set the Redirect URI to:
#   #   FRONTEND_BASE_URL + /api/auth/keycloak/callback
#   #   e.g. http://localhost:3069/api/auth/keycloak/callback

## Discord (OAuth2) – optional

# Example (uncomment and fill in to enable Discord SSO for admins):
# AUTH_DISCORD_ENABLED=true
# DISCORD_CLIENT_ID=123456789012345678
# DISCORD_CLIENT_SECRET=your-discord-client-secret
#   # In your Discord application, set the Redirect URL to:
#   #   FRONTEND_BASE_URL + /api/auth/discord/callback
#   #   e.g. http://localhost:3069/api/auth/discord/callback

## GitHub (OAuth2) – optional

# Example (uncomment and fill in to enable GitHub SSO for admins/contributors):
# AUTH_GITHUB_ENABLED=true
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
#   # In your GitHub OAuth app, set the Authorization callback URL to:
#   #   FRONTEND_BASE_URL + /api/auth/github/callback
#   #   e.g. http://localhost:3069/api/auth/github/callback

############################
# ---- Logging & debug ----
############################

# Log level: trace | debug | info | warn | error | fatal
# When LOG_LEVEL=debug, DB verbose and DB values logging are enabled automatically.
LOG_LEVEL=info

# Set to false to disable per-request HTTP logs (still logs 4xx/5xx) – optional
# LOG_HTTP_REQUESTS=true

# Per-query DB logs (SQL, params, row counts). Auto-enabled when LOG_LEVEL=debug.
# LOG_DB_VERBOSE=true

# When DB verbose is on, also log result rows (redacted). Auto-enabled when LOG_LEVEL=debug.
# Set LOG_DB_VALUES=false to disable even in debug.
# LOG_DB_VALUES=false

# Enable verbose RCON success logs – optional
# LOG_RCON_VERBOSE=false

################################
# ---- CORS / WebSockets ------- 
################################

# Allowed CORS origin(s) for Socket.IO and API (comma-separated) – optional
# In Docker with Caddy, this is usually handled at the proxy layer.
# CORS_ORIGIN=*

#####################################
# ---- Optional: simulation mode ----
#####################################

# Allow enabling "simulation" features in production (advanced) – optional
# MATCHZY_ENABLE_SIMULATION_IN_PROD=false

###########################
# ---- Misc / tooling ----
###########################

# GitHub token used by fetchCS2Maps to call the GitHub API – optional
# GITHUB_TOKEN=

# Playwright base URL for E2E tests – optional (defaults to http://localhost:3069 in tests)
# PLAYWRIGHT_BASE_URL=http://localhost:3069

# Steam ID to use for the test admin in Playwright/tests/scripts – optional
# TEST_STEAM_ID=76561198000000001